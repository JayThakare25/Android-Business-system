<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_margin="8dp"
    android:background="?attr/colorSurfaceVariant">
    
    <TextView android:id="@+id/tv_customer_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:textSize="16sp"/>
    <TextView android:id="@+id/tv_customer_phone" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tv_loyalty_points" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/colorPrimary"/>
</LinearLayout>
