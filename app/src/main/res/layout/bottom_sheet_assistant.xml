<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp"
    android:background="?attr/colorSurface">

    <TextView
        android:id="@+id/tv_ai_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gemini Business Assistant"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:id="@+id/scroll_response"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_ai_title">
        
        <TextView
            android:id="@+id/tv_ai_response"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hello! I am your AI. How can I help you optimize operations today?" 
            android:textSize="16sp"/>
    </ScrollView>

    <EditText
        android:id="@+id/et_prompt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Ask about sales, stock, etc..."
        app:layout_constraintTop_toBottomOf="@id/scroll_response"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_send_prompt" />

    <Button
        android:id="@+id/btn_send_prompt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Send"
        app:layout_constraintBottom_toBottomOf="@id/et_prompt"
        app:layout_constraintEnd_toEndOf="parent" />
        
    <ProgressBar
        android:id="@+id/progress_ai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/scroll_response"
        app:layout_constraintBottom_toBottomOf="@id/scroll_response"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
